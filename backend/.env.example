NODE_ENV=development
PORT=5000
JWT_SECRET=replace_with_a_long_random_secret
REFRESH_TOKEN_SECRET=replace_with_another_long_random_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
GOOGLE_CLIENT_ID=your_google_client_id_here

# Mobile OTP auth hardening
OTP_PEPPER=replace_with_a_long_random_secret_for_otp_hashing
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX_REQUESTS=3

# OTP provider options: mock | twilio
# For production, use `twilio` to deliver real SMS OTP.
OTP_PROVIDER=twilio
OTP_EXPOSE_IN_RESPONSE=false
OTP_MESSAGE_TEMPLATE=Your FinMan OTP is {{OTP}}. It expires in {{TTL}} minutes. Do not share this code.

# Twilio settings (required when OTP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional Turso config (falls back to local.db when URL is omitted)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:5173

# Optional performance tuning
ANALYTICS_CACHE_TTL_MS=30000
ANALYTICS_CACHE_MAX_ENTRIES=500
ANALYTICS_SLOW_QUERY_MS=250
ANALYTICS_LOG_ALL_TIMINGS=false
RECURRING_JOB_ENABLED=true
RECURRING_JOB_INTERVAL_MS=600000
RECURRING_JOB_LEASE_MS=1200000
RECURRING_JOB_INSTANCE_ID=
