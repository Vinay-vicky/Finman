NODE_ENV=development
PORT=5000
JWT_SECRET=replace_with_a_long_random_secret
REFRESH_TOKEN_SECRET=replace_with_another_long_random_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
GOOGLE_CLIENT_ID=your_google_client_id_here

# Optional Turso config (falls back to local.db when URL is omitted)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:5173

# Optional performance tuning
ANALYTICS_CACHE_TTL_MS=30000
ANALYTICS_CACHE_MAX_ENTRIES=500
ANALYTICS_SLOW_QUERY_MS=250
ANALYTICS_LOG_ALL_TIMINGS=false
RECURRING_JOB_ENABLED=true
RECURRING_JOB_INTERVAL_MS=600000
RECURRING_JOB_LEASE_MS=1200000
RECURRING_JOB_INSTANCE_ID=
